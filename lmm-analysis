<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LMM Analysis</title>

  <script>
    window.MathJax = {
      tex: {
        inlineMath: [["\\(", "\\)"]],
        displayMath: [["\\[", "\\]"]]
      },
      svg: {
        fontCache: "global"
      }
    };
  </script>
  <script async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"></script>

  <style>
    * {
      box-sizing: border-box;
    }

    :root {
      --purple: rgba(211, 140, 255, 0.95);
      --purple-soft: rgba(211, 140, 255, 0.72);
      --blue: rgba(102, 204, 255, 0.88);
      --text: rgba(255, 255, 255, 0.90);
      --muted: rgba(255, 255, 255, 0.68);
      --panel: rgba(0, 0, 0, 0.56);
      --border: rgba(255, 255, 255, 0.15);
    }

    html,
    body {
      margin: 0;
      padding: 0;
      width: 100%;
      min-height: 100vh;
      font-family: Arial, "Noto Sans KR", sans-serif;
      color: white;
      overflow-x: hidden;
      background-color: #000;
    }

    body {
      position: relative;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: url("images/lmm%20background.jpeg") center / cover no-repeat;
      opacity: 0.7;
      z-index: 0;
      pointer-events: none;
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      background:
        radial-gradient(
          circle at 18% 18%,
          rgba(175, 100, 255, 0.17),
          transparent 32%
        ),
        linear-gradient(
          rgba(0, 0, 0, 0.40),
          rgba(0, 0, 0, 0.88)
        );
      z-index: 0;
      pointer-events: none;
    }

    .page-container {
      position: relative;
      z-index: 1;
      width: 100%;
      min-height: 100vh;
      padding: 34px;
    }

    .top-navigation {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      width: 100%;
      margin-bottom: 28px;
    }

    .submenu-group {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
      gap: 12px;
    }

    .nav-button,
    .submenu-tab {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 9px 15px;
      border-radius: 999px;
      text-decoration: none;
      color: white;
      font-size: 15px;
      font-weight: 600;
      line-height: 1.2;
      transition:
        background 0.25s ease,
        border-color 0.25s ease,
        transform 0.25s ease,
        box-shadow 0.25s ease;
    }

    .nav-button {
      background: rgba(255, 255, 255, 0.10);
      border: 1px solid rgba(255, 255, 255, 0.55);
    }

    .nav-button:hover {
      background: rgba(255, 255, 255, 0.18);
      transform: translateX(-3px);
      box-shadow: 0 0 18px rgba(102, 204, 255, 0.35);
    }

    .submenu-tab {
      position: relative;
      overflow: hidden;
      background:
        linear-gradient(
          135deg,
          rgba(116, 70, 180, 0.60),
          rgba(38, 94, 158, 0.52)
        );
      border: 1px solid rgba(211, 170, 255, 0.72);
      box-shadow:
        0 0 12px rgba(180, 105, 255, 0.18),
        inset 0 0 12px rgba(255, 255, 255, 0.04);
    }

    .submenu-tab::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(
          110deg,
          transparent 20%,
          rgba(255, 255, 255, 0.18) 50%,
          transparent 80%
        );
      transform: translateX(-120%);
      transition: transform 0.45s ease;
    }

    .submenu-tab:hover,
    .submenu-tab[aria-current="page"] {
      border-color: rgba(225, 195, 255, 0.96);
      background:
        linear-gradient(
          135deg,
          rgba(135, 78, 205, 0.76),
          rgba(43, 112, 185, 0.68)
        );
      transform: translateY(-2px);
      box-shadow:
        0 0 18px rgba(188, 120, 255, 0.38),
        0 8px 20px rgba(0, 0, 0, 0.22);
    }

    .submenu-tab:hover::before {
      transform: translateX(120%);
    }

    .tab-icon {
      margin-right: 8px;
      font-size: 16px;
    }

    .page-shell {
      width: min(1800px, 96vw);
      margin: 0;
    }

    .page-header {
      margin-bottom: 34px;
    }

    h1 {
      margin: 0;
      font-size: clamp(38px, 4.5vw, 64px);
      line-height: 1.15;
      font-weight: 700;
      text-align: left;
      color: rgba(255, 255, 255, 0.98);
      text-shadow:
        0 0 8px rgba(211, 140, 255, 0.65),
        0 0 18px rgba(211, 140, 255, 0.42),
        0 0 30px rgba(150, 80, 255, 0.24);
    }

    .header-line {
      width: min(360px, 72vw);
      height: 2px;
      margin-top: 18px;
      background: linear-gradient(
        90deg,
        rgba(220, 170, 255, 0.95),
        rgba(150, 100, 255, 0.45),
        transparent
      );
      box-shadow: 0 0 12px rgba(190, 120, 255, 0.55);
    }

    .overview {
      max-width: 1320px;
      margin-bottom: 42px;
    }

    .overview-list {
      margin: 0;
      padding-left: 26px;
    }

    .overview-list li {
      margin: 10px 0;
      padding-left: 6px;
      font-size: 18px;
      line-height: 1.75;
      color: var(--text);
      text-shadow: 0 0 5px rgba(0, 0, 0, 0.85);
    }

    .overview-list li::marker {
      color: var(--purple);
      font-size: 1.15em;
    }

    .analysis-section {
      margin-bottom: 52px;
    }

    .section-title {
      display: inline-block;
      margin: 0 0 24px;
      padding-bottom: 8px;
      font-size: clamp(25px, 2.4vw, 34px);
      line-height: 1.25;
      color: rgba(255, 255, 255, 0.98);
      border-bottom: 2px solid var(--purple-soft);
      text-shadow:
        0 0 8px rgba(211, 140, 255, 0.50),
        0 0 16px rgba(211, 140, 255, 0.25);
    }

    .subsection-title {
      margin: 0 0 14px;
      font-size: 22px;
      line-height: 1.4;
      color: rgba(255, 255, 255, 0.97);
    }

    .card-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(230px, 1fr));
      gap: 18px;
    }

    .card-grid.two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .card-grid.three {
      grid-template-columns: repeat(3, minmax(250px, 1fr));
    }

    .info-card,
    .method-card,
    .equation-card,
    .note-card {
      min-width: 0;
      padding: 23px 24px;
      background: var(--panel);
      border-top: 2px solid rgba(102, 204, 255, 0.72);
      box-shadow:
        0 8px 24px rgba(0, 0, 0, 0.24),
        0 0 16px rgba(80, 160, 255, 0.07);
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
    }

    .method-card {
      border-left: 3px solid rgba(102, 204, 255, 0.72);
      border-top: 0;
    }

    .equation-card {
      border-left: 4px solid rgba(211, 140, 255, 0.88);
      border-top: 0;
      background:
        linear-gradient(
          135deg,
          rgba(42, 20, 55, 0.72),
          rgba(14, 20, 38, 0.70)
        );
    }

    .note-card {
      border-top-color: rgba(255, 196, 102, 0.82);
    }

    .card-title {
      margin: 0 0 14px;
      font-size: 21px;
      line-height: 1.35;
      color: rgba(255, 255, 255, 0.97);
    }

    .metric-value {
      display: block;
      margin: 4px 0 10px;
      font-size: 27px;
      font-weight: 700;
      line-height: 1.3;
      color: #dfb5ff;
    }

    .text-list,
    .definition-list,
    .warning-list {
      margin: 0;
      padding-left: 21px;
    }

    .text-list li,
    .definition-list li,
    .warning-list li {
      margin: 8px 0;
      font-size: 15px;
      line-height: 1.68;
      color: rgba(255, 255, 255, 0.82);
    }

    .text-list li::marker,
    .definition-list li::marker {
      color: rgba(120, 200, 255, 0.90);
    }

    .warning-list li::marker {
      color: rgba(255, 196, 102, 0.95);
    }

    .highlight {
      color: #dfb5ff;
      font-weight: 700;
    }

    .blue-highlight {
      color: #8fd8ff;
      font-weight: 700;
    }

    .pipeline {
      display: grid;
      grid-template-columns: repeat(7, minmax(150px, 1fr));
      gap: 12px;
      align-items: stretch;
    }

    .pipeline-step {
      position: relative;
      min-height: 150px;
      padding: 19px 16px;
      background: rgba(0, 0, 0, 0.58);
      border: 1px solid rgba(211, 170, 255, 0.40);
      box-shadow: 0 8px 22px rgba(0, 0, 0, 0.24);
    }

    .pipeline-step:not(:last-child)::after {
      content: "→";
      position: absolute;
      top: 50%;
      right: -13px;
      z-index: 2;
      transform: translateY(-50%);
      font-size: 22px;
      color: rgba(211, 170, 255, 0.95);
      text-shadow: 0 0 8px rgba(211, 140, 255, 0.60);
    }

    .step-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      margin-bottom: 12px;
      border-radius: 50%;
      background: rgba(131, 79, 190, 0.68);
      font-size: 14px;
      font-weight: 700;
    }

    .step-title {
      display: block;
      margin-bottom: 8px;
      font-size: 16px;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.96);
    }

    .step-text {
      font-size: 13px;
      line-height: 1.55;
      color: rgba(255, 255, 255, 0.70);
    }

    .equation {
      width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      padding: 9px 2px 13px;
      font-size: 23px;
      line-height: 1.8;
      color: rgba(242, 222, 255, 0.99);
    }

    .equation.large {
      font-size: 26px;
    }

    .equation mjx-container {
      margin: 0 !important;
      text-align: left !important;
      max-width: 100%;
    }

    .formula-label {
      margin: 0 0 10px;
      font-size: 19px;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.96);
    }

    .model-block {
      display: grid;
      grid-template-columns: minmax(0, 1.28fr) minmax(320px, 0.72fr);
      gap: 20px;
      align-items: stretch;
    }

    .term-table-wrap,
    .data-table-wrap {
      width: 100%;
      overflow-x: auto;
      border: 1px solid var(--border);
      background: rgba(0, 0, 0, 0.48);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
      line-height: 1.5;
    }

    .term-table {
      min-width: 720px;
    }

    .data-table {
      min-width: 670px;
    }

    th,
    td {
      padding: 12px 11px;
      border-right: 1px solid rgba(255, 255, 255, 0.11);
      border-bottom: 1px solid rgba(255, 255, 255, 0.11);
      vertical-align: top;
    }

    th:last-child,
    td:last-child {
      border-right: 0;
    }

    tbody tr:last-child td,
    tbody tr:last-child th {
      border-bottom: 0;
    }

    thead th {
      background: rgba(138, 79, 190, 0.34);
      color: rgba(255, 255, 255, 0.98);
      font-weight: 700;
      text-align: left;
    }

    tbody th {
      background: rgba(255, 255, 255, 0.06);
      color: rgba(229, 190, 255, 0.98);
      font-weight: 700;
      text-align: left;
    }

    td {
      color: rgba(255, 255, 255, 0.82);
    }

    code {
      padding: 2px 5px;
      border-radius: 4px;
      background: rgba(255, 255, 255, 0.08);
      color: #dcb2ff;
      font-family: Consolas, "Courier New", monospace;
      font-size: 0.94em;
      word-break: break-word;
    }

    .load-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(120px, 1fr));
      gap: 12px;
      margin-top: 16px;
    }

    .load-item {
      padding: 17px;
      text-align: center;
      background: rgba(0, 0, 0, 0.54);
      border: 1px solid rgba(211, 170, 255, 0.34);
    }

    .load-name {
      display: block;
      margin-bottom: 7px;
      font-size: 15px;
      color: rgba(255, 255, 255, 0.75);
    }

    .load-value {
      font-size: 22px;
      font-weight: 700;
      color: #dfb5ff;
    }

    .callout {
      margin-top: 18px;
      padding: 18px 20px;
      background: rgba(33, 18, 48, 0.72);
      border-left: 4px solid rgba(211, 140, 255, 0.88);
      font-size: 15px;
      line-height: 1.7;
      color: rgba(255, 255, 255, 0.82);
    }

    .callout.warning {
      background: rgba(49, 34, 14, 0.68);
      border-left-color: rgba(255, 196, 102, 0.90);
    }

    .output-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    .sheet-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 12px;
    }

    .sheet-item {
      padding: 12px 14px;
      background: rgba(255, 255, 255, 0.055);
      border: 1px solid rgba(255, 255, 255, 0.11);
      font-size: 13px;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.77);
    }

    .reference-list {
      margin: 0;
      padding-left: 22px;
    }

    .reference-list li {
      margin: 9px 0;
      font-size: 14px;
      line-height: 1.65;
      color: rgba(255, 255, 255, 0.72);
    }

    @media screen and (max-width: 1500px) {
      .card-grid {
        grid-template-columns: repeat(2, minmax(250px, 1fr));
      }

      .pipeline {
        grid-template-columns: repeat(4, minmax(160px, 1fr));
      }

      .pipeline-step:nth-child(4)::after {
        display: none;
      }
    }

    @media screen and (max-width: 1150px) {
      .card-grid.three,
      .model-block,
      .output-grid {
        grid-template-columns: 1fr;
      }

      .pipeline {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .pipeline-step:nth-child(even)::after {
        display: none;
      }

      .pipeline-step:nth-child(4)::after {
        display: none;
      }
    }

    @media screen and (max-width: 900px) {
      .page-container {
        padding: 22px;
      }

      .page-shell {
        width: 100%;
      }

      h1 {
        font-size: 42px;
      }

      .card-grid,
      .card-grid.two,
      .card-grid.three {
        grid-template-columns: 1fr;
      }

      .load-grid,
      .sheet-list {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .equation,
      .equation.large {
        font-size: 21px;
      }
    }

    @media screen and (max-width: 560px) {
      .page-container {
        padding: 16px;
      }

      .top-navigation {
        align-items: stretch;
      }

      .top-navigation > .nav-button,
      .submenu-group {
        width: 100%;
      }

      .submenu-group {
        flex-direction: column;
        align-items: stretch;
      }

      .nav-button,
      .submenu-tab {
        width: 100%;
      }

      h1 {
        font-size: 34px;
      }

      .overview-list li {
        font-size: 16px;
      }

      .pipeline {
        grid-template-columns: 1fr;
      }

